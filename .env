# Environment Variables for Spaceverse Application

# MongoDB Configuration - Local MongoDB (service is running on this machine)
MONGODB_URI=mongodb://localhost:27017/spaceverse

# Application Configuration
PORT=5000

# NASA API Key (replace with your actual key from https://api.nasa.gov)
NASA_API_KEY=DEMO_KEY

# Gemini API Key (replace with your actual key from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
